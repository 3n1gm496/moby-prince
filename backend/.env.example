# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Google Cloud ──────────────────────────────────────────────────────────────

# GCP project ID (required)
GOOGLE_CLOUD_PROJECT=your-project-id

# Discovery Engine region — use 'eu' for GDPR-compliant EU data residency,
# 'global' for lowest latency in dev/staging (required, default: eu)
GCP_LOCATION=eu

# Vertex AI Search engine ID (required)
# Found in: Cloud Console → Vertex AI Search → Apps → [your app] → ID
ENGINE_ID=your-engine-id

# Datastore ID (optional but required for chunk-level evidence lookup)
# Found in: Cloud Console → Vertex AI Search → Data Stores → [your store] → ID
# Enables: GET /api/evidence/documents/:id/chunks
DATA_STORE_ID=your-datastore-id

# ── Authentication ────────────────────────────────────────────────────────────

# Option A (recommended): Application Default Credentials
#   Local / docker-compose:  gcloud auth application-default login
#   Cloud Run:               Workload Identity / attached service account (no config needed)
#
# Option B: Service Account key file
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# API key for protecting all /api/* endpoints (optional but strongly recommended in production).
# When set, every request must include the key via:
#   Header:  X-API-Key: <key>
# Generate a strong random key: openssl rand -hex 32
# API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=development

# Allowed CORS origin for the frontend
# docker-compose:  http://localhost:5173
# Cloud Run:       https://your-frontend-domain.com
FRONTEND_ORIGIN=http://localhost:5173

# Log level: debug | info | warn | error (default: debug in dev, info in prod)
LOG_LEVEL=debug

# ── Search quality ────────────────────────────────────────────────────────────

# Adjacent chunks to include around each matched chunk in :answer responses.
# Increases answer context quality at the cost of more tokens/latency.
# Default: 1 (one chunk before and after each match)
# CHUNK_CONTEXT_PREV=1
# CHUNK_CONTEXT_NEXT=1

# ── Storage (optional) ───────────────────────────────────────────────────────
# GCS bucket name — enables /api/storage/* endpoints (browse, upload, download)
# GCS_BUCKET=your-project-corpus

# ── BigQuery evidence layer (optional) ───────────────────────────────────────
# Defaults to GOOGLE_CLOUD_PROJECT / 'evidence' if not set
# BQ_PROJECT_ID=your-project-id
# BQ_DATASET_ID=evidence
# BQ_LOCATION=EU

# ── Firestore (optional) ─────────────────────────────────────────────────────
# Database ID for session persistence (default: "(default)")
# FIRESTORE_DB=(default)

# ── Gemini / Vertex AI generative models ─────────────────────────────────────
# Region for Gemini 2.0 Flash calls — must have Vertex AI Gemini availability.
# us-central1 has the broadest model availability; eu regions may have limited quota.
# GEMINI_LOCATION=us-central1

# Document AI region (defaults to GCP_LOCATION)
# DOCAI_LOCATION=eu

# ── Daily budget limits (circuit breaker) ────────────────────────────────────
# Maximum Gemini / BigQuery calls per day before the server returns 429.
# Resets at midnight UTC. Useful to cap accidental runaway costs.
# DAILY_GEMINI_LIMIT=500
# DAILY_BQ_LIMIT=2000
