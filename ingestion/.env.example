# Ingestion pipeline environment variables.
# Copy to .env and fill in your values before running locally.
# In Cloud Run Jobs these are set via --set-env-vars or Secret Manager.

# ── Google Cloud (required) ───────────────────────────────────────────────────

GOOGLE_CLOUD_PROJECT=your-project-id

# Discovery Engine location (default: eu)
GCP_LOCATION=eu

# Vertex AI Search engine and datastore IDs
ENGINE_ID=your-engine-id
DATA_STORE_ID=your-datastore-id

# ── Authentication ────────────────────────────────────────────────────────────

# Application Default Credentials (recommended):
#   gcloud auth application-default login
#
# Service Account key (alternative):
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── GCS Buckets ───────────────────────────────────────────────────────────────
# Leave unset to use the local filesystem (for development/testing)

# BUCKET_RAW=your-project-corpus-raw
# BUCKET_NORMALIZED=your-project-corpus-normalized
# BUCKET_QUARANTINE=your-project-corpus-quarantine

# ── Document AI (required only for PDFs > 50 MB) ─────────────────────────────

# DOCAI_PROCESSOR_ID=your-processor-id
# DOCAI_LOCATION=eu

# ── State store ───────────────────────────────────────────────────────────────

# 'firestore' (default in Cloud Run) | 'file' (local dev) | 'memory' (tests)
STORE_TYPE=file

# ── Local filesystem directories (used when GCS buckets are not set) ─────────

# LOCAL_DIR_RAW=./corpus/raw
# LOCAL_DIR_NORMALIZED=./corpus/normalized
# LOCAL_DIR_QUARANTINE=./corpus/quarantine
# LOCAL_DIR_STATE=./corpus/.state

# ── Splitting thresholds ──────────────────────────────────────────────────────

# SPLIT_MAX_BYTES=2000000    # 2 MB per part (Discovery Engine limit: 2.5 MB)
# SPLIT_MAX_CHARS=800000
# SPLIT_PDF_WARN=10000000    # 10 MB: warn, proceed
# SPLIT_PDF_FATAL=50000000   # 50 MB: must use Document AI

# ── Retry policy ─────────────────────────────────────────────────────────────

# RETRY_MAX_ATTEMPTS=3
# RETRY_INITIAL_DELAY_MS=2000
# RETRY_MAX_DELAY_MS=60000

# ── Misc ──────────────────────────────────────────────────────────────────────

LOG_LEVEL=info

# Set to 'true' to skip the actual Discovery Engine import (dry run)
# INDEX_DRY_RUN=false
